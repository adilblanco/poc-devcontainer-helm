# =============================================================================
# config.env — single source of truth for all devcontainer variables.
#
# This is the ONLY file to update when upgrading Airflow or infrastructure.
# Sourced with 'set -a' in post-create.sh so all variables are automatically
# exported and visible to envsubst, helm --set, and docker --build-arg.
# =============================================================================

# Kind cluster identity. CLUSTER_NAME is the cluster passed to 'kind'; NODE_NAME
# follows Kind's '<cluster>-control-plane' convention and is used by tools that
# talk to the node's containerd directly (tools/kind-images.sh).
# The project path is resolved at runtime as WORKSPACE_DIR in the hooks.
CLUSTER_NAME="local"
NODE_NAME="${CLUSTER_NAME}-control-plane"

# Airflow version (Docker image apache/airflow:X.Y.Z)
AIRFLOW_VERSION="2.11.0"

# Apache Airflow Helm chart version (distinct from the Airflow application version).
# Compatibility matrix: https://airflow.apache.org/docs/helm-chart/stable/index.html
AIRFLOW_CHART_VERSION="1.21.0"

# Custom image name and tag — must match defaultAirflowRepository in values.yaml.
CUSTOM_IMAGE_NAME="bi-airflow-custom-img"
CUSTOM_IMAGE_TAG="1.0.0"

# Helm CLI version installed in the devcontainer.
HELM_CLI_VERSION="v4.0.5"

# kubectl CLI version. Pin explicitly rather than tracking the floating
# https://dl.k8s.io/release/stable.txt so builds stay reproducible.
KUBECTL_VERSION="v1.36.1"

# Kind version. Pin explicitly rather than the floating 'latest' channel —
# the bundled kindest/node image (and thus the cluster's Kubernetes version)
# is tied to this. https://github.com/kubernetes-sigs/kind/releases
KIND_VERSION="v0.32.0"

# TODO: pin the PostgreSQL version to match production.
#   The chart's bundled DB is the Bitnami postgresql subchart, whose image tags
#   are NOT bare majors like "16" — they look like "16.4.0-debian-12-r0". So you
#   must pin the full tag (check the tags available for the Bitnami postgresql
#   image shipped with chart 1.21.0), not just the major.
#   1. Replace this block with the full tag, e.g.: POSTGRES_VERSION="16.4.0-debian-12-r0"
#   2. In post-create.sh, alongside the other --set flags in the
#      'helm upgrade --install airflow' command (just above '--timeout 10m'), add:
#        --set postgresql.image.tag="${POSTGRES_VERSION}" \
#   Note: Airflow 2.x supports PostgreSQL 12–16 (the major within the tag).
